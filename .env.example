# Google Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
SPREADSHEET_ID=your_spreadsheet_id_here

# Meta Ads
META_ACCESS_TOKEN=your_long_lived_token_here
